<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIMELINE"
            android:textColor="@color/accent_red"
            android:textSize="26sp"
            android:letterSpacing="0.05" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:id="@+id/scaleRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/timelineSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_main"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            android:background="@drawable/card_period"
            android:paddingStart="16dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="34dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingBottom="22dp">
                <TextView android:id="@+id/axisMax"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:text=""
                    android:textColor="@color/axis_dim" android:textSize="10sp"
                    android:gravity="end|top" android:paddingEnd="4dp" />
                <TextView android:id="@+id/axisMid"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:text=""
                    android:textColor="@color/axis_dim" android:textSize="10sp"
                    android:gravity="end|top" android:paddingEnd="4dp" />
                <TextView
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:text="0"
                    android:textColor="@color/axis_dim" android:textSize="10sp"
                    android:gravity="end|bottom" android:paddingEnd="4dp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <com.vasil.stepcore.TimelineView
                    android:id="@+id/timeline"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent" />
            </HorizontalScrollView>
        </LinearLayout>

        <TextView
            android:id="@+id/timelineDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Нажми на столбец для деталей"
            android:textColor="@color/text_main"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            android:background="@drawable/card_column"
            android:paddingStart="16dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginTop="10dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <View android:layout_width="10dp" android:layout_height="10dp"
                android:background="@color/accent_blue" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ходьба" android:textColor="@color/text_dim"
                android:textSize="12sp" android:layout_marginStart="4dp"
                android:layout_marginEnd="14dp" />
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:background="@color/accent_red" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="бег" android:textColor="@color/text_dim"
                android:textSize="12sp" android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/timelineHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
