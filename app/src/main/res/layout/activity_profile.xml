<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПРОФИЛЬ"
            android:textColor="@color/accent_red"
            android:fontFamily="sans-serif-black"
            android:textSize="26sp"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/dataToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ДАННЫЕ  ▾"
            android:textColor="@color/text_dim"
            android:fontFamily="sans-serif-condensed"
            android:textSize="14sp"
            android:letterSpacing="0.05"
            android:paddingTop="18dp"
            android:paddingBottom="10dp" />

        <LinearLayout
            android:id="@+id/dataContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_asym"
            android:padding="16dp"
            android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ВЕС, КГ" android:textColor="@color/text_dim"
                android:fontFamily="sans-serif-condensed" android:textSize="12sp"
                android:letterSpacing="0.05" />
            <EditText android:id="@+id/weightInput" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="numberDecimal"
                android:textColor="@color/text_main" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ГРУЗ, КГ (рюкзак и т.п., 0 = нет)" android:textColor="@color/text_dim"
                android:fontFamily="sans-serif-condensed" android:textSize="12sp"
                android:letterSpacing="0.05" android:layout_marginTop="8dp" />
            <EditText android:id="@+id/loadInput" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="numberDecimal"
                android:textColor="@color/text_main" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="РОСТ, СМ" android:textColor="@color/text_dim"
                android:fontFamily="sans-serif-condensed" android:textSize="12sp"
                android:letterSpacing="0.05" android:layout_marginTop="8dp" />
            <EditText android:id="@+id/heightInput" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="number"
                android:textColor="@color/text_main" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ВОЗРАСТ" android:textColor="@color/text_dim"
                android:fontFamily="sans-serif-condensed" android:textSize="12sp"
                android:letterSpacing="0.05" android:layout_marginTop="8dp" />
            <EditText android:id="@+id/ageInput" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="number"
                android:textColor="@color/text_main" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ЦЕЛЬ ШАГОВ В ДЕНЬ" android:textColor="@color/text_dim"
                android:fontFamily="sans-serif-condensed" android:textSize="12sp"
                android:letterSpacing="0.05" android:layout_marginTop="8dp" />
            <EditText android:id="@+id/goalInput" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="number"
                android:textColor="@color/text_main" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ПОЛ" android:textColor="@color/text_dim"
                android:fontFamily="sans-serif-condensed" android:textSize="12sp"
                android:letterSpacing="0.05" android:layout_marginTop="12dp" />
            <RadioGroup android:id="@+id/sexGroup" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <RadioButton android:id="@+id/sexM" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Мужской"
                    android:textColor="@color/text_main" />
                <RadioButton android:id="@+id/sexF" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Женский"
                    android:textColor="@color/text_main" android:layout_marginStart="20dp" />
            </RadioGroup>

            <Button android:id="@+id/saveButton" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="Сохранить"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПАСПОРТ"
            android:textColor="@color/accent_red"
            android:fontFamily="sans-serif-black"
            android:textSize="15sp"
            android:letterSpacing="0.08"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/passportContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
