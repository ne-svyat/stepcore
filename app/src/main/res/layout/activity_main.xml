<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/modeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Покой"
                android:textColor="@color/text_main"
                android:fontFamily="sans-serif-condensed"
                android:textSize="14sp"
                android:letterSpacing="0.08"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />

            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/cargoChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Груз выкл"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp">

            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="188dp">

                <com.vasil.stepcore.CrystalRingView
                    android:id="@+id/progressRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/lapBadgeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/accent_blue"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/stepsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_main"
                    android:fontFamily="sans-serif-black"
                    android:textSize="34sp" />

                <TextView
                    android:id="@+id/goalText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% · цель 10 000"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@color/accent_blue" />
                    <TextView
                        android:id="@+id/walkShareText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 ходьба"
                        android:textColor="@color/text_dim"
                        android:textSize="12sp"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@color/accent_red" />
                    <TextView
                        android:id="@+id/runShareText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 бег"
                        android:textColor="@color/text_dim"
                        android:textSize="12sp"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/heroCompareText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_dim"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:padding="10dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/distanceValueText"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0.00 км" android:textColor="@color/text_main" android:textSize="14sp" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="дистанция" android:textColor="@color/text_dim" android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:padding="10dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/activeTimeText"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="@color/text_main" android:textSize="14sp" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="активное время" android:textColor="@color/text_dim" android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/activeKcalChip"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:padding="10dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/activeKcalValueText"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 ккал" android:textColor="@color/text_main" android:textSize="14sp" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="активные" android:textColor="@color/text_dim" android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/totalKcalChip"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface"
                android:padding="10dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/totalKcalValueText"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 ккал" android:textColor="@color/text_main" android:textSize="14sp" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="всего за день" android:textColor="@color/text_dim" android:textSize="10sp" />
            </LinearLayout>
        </GridLayout>

        <TextView
            android:id="@+id/accuracyBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text=""
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:padding="6dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/yesterdayCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_asym"
            android:padding="16dp"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="ВЧЕРА"
                    android:textColor="@color/text_dim"
                    android:letterSpacing="0.06"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/ySteps"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="нет данных" android:textColor="@color/text_dim" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/yesterdayDetailsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <LinearLayout
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:id="@+id/yKm" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text=""
                            android:textColor="@color/text_dim" android:textSize="12sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="дистанция" android:textColor="@color/axis_dim" android:textSize="9sp" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:id="@+id/yTime" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text=""
                            android:textColor="@color/text_dim" android:textSize="12sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="активно" android:textColor="@color/axis_dim" android:textSize="9sp" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:id="@+id/yTotalKcal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text=""
                            android:textColor="@color/text_dim" android:textSize="12sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="всего ккал" android:textColor="@color/axis_dim" android:textSize="9sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/yBreakdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/axis_dim"
                    android:textSize="11sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/yDiff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_dim"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Остановлено"
            android:textColor="@color/text_dim"
            android:textSize="13sp"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/toggleButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Старт"
            android:textSize="17sp"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:id="@+id/expeditionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_asym_amber"
            android:padding="14dp"
            android:layout_marginTop="14dp">

            <com.vasil.stepcore.survival.SeasonDiamondView
                android:id="@+id/expeditionSeasonView"
                android:layout_width="52dp"
                android:layout_height="52dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/expeditionLabelText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ЭКСПЕДИЦИЯ"
                    android:textColor="@color/accent_amber_bright"
                    android:letterSpacing="0.06"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/expeditionDayText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Нет активной экспедиции"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/expeditionSubText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Начать →"
                    android:textColor="@color/accent_amber"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button android:id="@+id/historyButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="История"
                android:textColor="@color/text_main" />
            <Button android:id="@+id/statsButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Статистика"
                android:textColor="@color/text_main" />
            <Button android:id="@+id/timelineButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Timeline"
                android:textColor="@color/text_main" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/profileButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Профиль"
                android:textColor="@color/text_main" />
            <Button android:id="@+id/calibrationButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Калибровка"
                android:textColor="@color/text_main" />
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/hapticSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Вибрация на шаг"
            android:textColor="@color/text_main"
            android:textSize="15sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/toolsToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙  Инструменты  ▾"
            android:textColor="@color/text_dim"
            android:fontFamily="sans-serif-condensed"
            android:textSize="14sp"
            android:letterSpacing="0.05"
            android:paddingTop="18dp"
            android:paddingBottom="10dp" />

        <LinearLayout
            android:id="@+id/toolsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Калибровки перенесены на отдельный экран — кнопка «Калибровка» выше."
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/detailLogSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Детальный лог (диагностика)"
                android:textColor="@color/text_main"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/diagButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Диагностика: старт"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/diagText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_dim"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:layout_marginTop="12dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
