<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:id="@+id/modeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Покой"
            android:textColor="@color/text_main"
            android:fontFamily="sans-serif-condensed"
            android:textSize="14sp"
            android:letterSpacing="0.08"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginTop="8dp" />

        <FrameLayout
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_marginTop="20dp">

            <com.vasil.stepcore.ProgressRingView
                android:id="@+id/progressRing"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/stepsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_main"
                    android:fontFamily="sans-serif-black"
                    android:textSize="46sp" />

                <TextView
                    android:id="@+id/activeTimeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/accent_blue"
                    android:textSize="14sp"
                    android:layout_marginTop="1dp" />

                <TextView
                    android:id="@+id/goalText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% · цель 10 000"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/todayKmKcal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_main"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp">

            <View android:layout_width="10dp" android:layout_height="10dp"
                android:background="@color/accent_blue" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ходьба" android:textColor="@color/text_dim"
                android:textSize="12sp" android:layout_marginStart="4dp"
                android:layout_marginEnd="14dp" />
            <View android:layout_width="10dp" android:layout_height="10dp"
                android:background="@color/accent_red" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="бег" android:textColor="@color/text_dim"
                android:textSize="12sp" android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/accuracyBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text=""
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:padding="6dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/statsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_asym"
            android:layout_marginTop="18dp">

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/accent_blue" />

            <TextView
                android:id="@+id/statsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_main"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:padding="16dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Остановлено"
            android:textColor="@color/text_dim"
            android:textSize="13sp"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/toggleButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Старт"
            android:textSize="17sp"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button android:id="@+id/historyButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="История"
                android:textColor="@color/text_main" />
            <Button android:id="@+id/statsButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Статистика"
                android:textColor="@color/text_main" />
            <Button android:id="@+id/timelineButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Timeline"
                android:textColor="@color/text_main" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/profileButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Профиль"
                android:textColor="@color/text_main" />
            <Button android:id="@+id/calibrationButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Калибровка"
                android:textColor="@color/text_main" />

            <Button android:id="@+id/survivalButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Экспедиция"
                android:textColor="@color/text_main" />
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/hapticSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Вибрация на шаг"
            android:textColor="@color/text_main"
            android:textSize="15sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/toolsToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙  Инструменты  ▾"
            android:textColor="@color/text_dim"
            android:fontFamily="sans-serif-condensed"
            android:textSize="14sp"
            android:letterSpacing="0.05"
            android:paddingTop="18dp"
            android:paddingBottom="10dp" />

        <LinearLayout
            android:id="@+id/toolsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Калибровки перенесены на отдельный экран — кнопка «Калибровка» выше."
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/detailLogSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Детальный лог (диагностика)"
                android:textColor="@color/text_main"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/diagButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Диагностика: старт"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/diagText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_dim"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:layout_marginTop="12dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
