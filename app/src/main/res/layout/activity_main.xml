<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="11dp">


        <com.vasil.stepcore.DoodleSceneView
            android:id="@+id/headerScene"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:layout_marginTop="7dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <FrameLayout
                android:layout_width="118dp"
                android:layout_height="172dp">

                <com.vasil.stepcore.CrystalRingView
                    android:id="@+id/progressRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/lapBadgeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/accent_blue"
                    android:textSize="15sp"
                    android:visibility="gone"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/stepsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_main"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="26sp"
                    android:autoSizeMaxTextSize="44sp"
                    android:autoSizeStepGranularity="1sp" />

                <TextView
                    android:id="@+id/goalText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% · цель 10 000"
                    android:textColor="@color/text_dim"
                    android:textSize="15sp"
                    android:layout_marginBottom="5dp" />

                <com.vasil.stepcore.SynxOrbView
                    android:id="@+id/synxOrb"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="end"
                    android:layout_marginBottom="2dp"
                    android:contentDescription="SYNX" />

                <com.vasil.stepcore.StrideBarView
                    android:id="@+id/strideBar"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="1dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/walkShareText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 ходьба"
                        android:textColor="@color/accent_blue"
                        android:textSize="13sp"
                        android:maxLines="1" />

                    <TextView
                        android:id="@+id/runShareText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 бег"
                        android:textColor="@color/accent_red"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:layout_marginStart="10dp" />
                </LinearLayout>


                <!-- ОТКАТ_V169: строка сравнения и кнопка вернулись на места -->
                <!-- ШАГ2_КНОПКА: состояние и Старт/Стоп занимают место
                     строки сравнения рядом с горой, а не отдельные полосы -->
                <TextView
                    android:id="@+id/heroCompareText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:text=""
                    android:textColor="@color/text_dim"
                    android:textSize="18sp" />

                <!-- ШАГ3_СТАТУС: режим и груз переехали сюда из верхней
                     полосы - заполняют простор справа от горы -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/modeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Покой"
                        android:textColor="@color/text_main"
                        android:textSize="15sp"
                        android:letterSpacing="0.06"
                        android:maxLines="1"
                        android:paddingLeft="11dp"
                        android:paddingRight="11dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp" />

                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" />

                    <com.vasil.stepcore.BackpackView
                        android:id="@+id/backpackView"
                        android:layout_width="30dp"
                        android:layout_height="30dp" />

                    <TextView
                        android:id="@+id/cargoChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Груз выкл"
                        android:textColor="@color/text_dim"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="СЧЁТ НЕ ИДЁТ"
                    android:textColor="@color/accent_red_bright"
                    android:textSize="13sp"
                    android:letterSpacing="0.04"
                    android:layout_marginTop="5dp" />

                <Button
                    android:id="@+id/toggleButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Старт"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />
            </LinearLayout>
        </LinearLayout>

        <com.vasil.stepcore.MotiveScrollView
            android:id="@+id/motiveScroll"
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/inclineLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Уклон: ровно"
            android:textColor="@color/text_dim"
            android:textSize="14sp"
            android:layout_marginTop="9dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/inclineUpButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="↗ В гору"
                android:textColor="@color/accent_amber_bright"
                android:textSize="14sp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/inclineFlatButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Ровно"
                android:textColor="@color/text_main"
                android:textSize="14sp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/inclineDownButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="↘ С горы"
                android:textColor="@color/accent_teal_bright"
                android:textSize="14sp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:id="@+id/distanceChip"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/distanceValueText"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0.00 км" android:textColor="@color/text_main" android:textSize="18sp" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="дистанция" android:textColor="@color/text_dim" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/activeTimeChip"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/activeTimeText"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="@color/text_main" android:textSize="18sp" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="активное время" android:textColor="@color/text_dim" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/activeKcalChip"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/activeKcalValueText"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 ккал" android:textColor="@color/text_main" android:textSize="18sp" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="активные" android:textColor="@color/text_dim" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/totalKcalChip"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_margin="4dp">
                <TextView
                    android:id="@+id/totalKcalValueText"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 ккал" android:textColor="@color/text_main" android:textSize="18sp" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="всего за день" android:textColor="@color/text_dim" android:textSize="13sp" />
            </LinearLayout>
        </GridLayout>

        <TextView
            android:id="@+id/accuracyBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text=""
            android:textColor="@color/text_dim"
            android:textSize="15sp"
            android:padding="6dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginTop="7dp">

            <FrameLayout
                android:id="@+id/yesterdayCard"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="match_parent"
                android:layout_marginEnd="5dp">

                <com.vasil.stepcore.DoodleSceneView
                    android:id="@+id/nightScene"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="11dp">

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ВЧЕРА" android:textColor="@color/accent_violet_bright"
                        android:letterSpacing="0.08" android:textSize="19sp" />

                    <TextView
                        android:id="@+id/ySteps"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="нет данных" android:textColor="@color/text_main"
                        android:textSize="31sp"
                        android:maxLines="2"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="19sp"
                        android:autoSizeMaxTextSize="31sp"
                        android:autoSizeStepGranularity="1sp"
                    android:textStyle="bold" android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:id="@+id/yesterdayDetailsGroup"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:visibility="gone">

                        <TextView android:id="@+id/yKm" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text=""
                            android:textColor="@color/accent_violet_bright" android:textSize="20sp"
                            android:layout_marginTop="8dp" />
                        <TextView android:id="@+id/yTime" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text=""
                            android:textColor="@color/accent_violet_bright" android:textSize="20sp" />
                        <TextView android:id="@+id/yTotalKcal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text=""
                            android:textColor="@color/accent_violet_bright" android:textSize="20sp" />
                        <TextView android:id="@+id/yBreakdown" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text=""
                            android:textColor="@color/text_dim" android:textSize="17sp"
                            android:layout_marginTop="4dp" />
                        <TextView android:id="@+id/yDiff" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text=""
                            android:textColor="@color/text_main" android:textSize="18sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/todayCard"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp">

                <com.vasil.stepcore.DoodleSceneView
                    android:id="@+id/dayScene"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="11dp">

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="СЕГОДНЯ" android:textColor="@color/accent_teal_bright"
                        android:letterSpacing="0.08" android:textSize="19sp" />

                    <TextView
                        android:id="@+id/tSteps"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/text_main"
                        android:textSize="31sp"
                        android:maxLines="2"
                        android:autoSizeTextType="uniform"
                        android:autoSizeMinTextSize="19sp"
                        android:autoSizeMaxTextSize="31sp"
                        android:autoSizeStepGranularity="1sp"
                    android:textStyle="bold" android:layout_marginTop="2dp" />

                    <TextView android:id="@+id/tKm" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text=""
                        android:textColor="@color/accent_teal_bright" android:textSize="20sp"
                        android:layout_marginTop="8dp" />
                    <TextView android:id="@+id/tTime" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text=""
                        android:textColor="@color/accent_teal_bright" android:textSize="20sp" />
                    <TextView android:id="@+id/tTotalKcal" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text=""
                        android:textColor="@color/accent_teal_bright" android:textSize="20sp" />
                    <TextView android:id="@+id/tBreakdown" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text=""
                        android:textColor="@color/text_dim" android:textSize="17sp"
                        android:layout_marginTop="4dp" />
                    <TextView android:id="@+id/tToGoal" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text=""
                        android:textColor="@color/accent_amber_bright" android:textSize="18sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>



        <!-- ШАГ1_ПОРЯДОК: навигация выше Экспедиции -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:id="@+id/profileButton"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:padding="11dp"
                android:layout_marginEnd="5dp">
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Профиль" android:textColor="@color/text_main" android:textSize="19sp" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="вес, рост, груз" android:textColor="@color/accent_blue_bright"
                    android:textSize="14sp" android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/analyticsTile"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginStart="5dp">

                <LinearLayout
                    android:id="@+id/analyticsStatsRow"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:paddingTop="10dp" android:paddingBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Аналитика" android:textColor="@color/text_main" android:textSize="19sp" />
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="статистика" android:textColor="@color/accent_teal_bright"
                        android:textSize="14sp" android:layout_marginTop="2dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/accent_teal" />

                <LinearLayout
                    android:id="@+id/analyticsTimelineRow"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:paddingTop="8dp" android:paddingBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Timeline" android:textColor="@color/text_main" android:textSize="17sp" />
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="лента дня" android:textColor="@color/accent_teal_bright"
                        android:textSize="13sp" android:layout_marginTop="1dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <com.vasil.stepcore.DoodleSceneView
                android:id="@+id/expeditionScene"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/expeditionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp">

            <com.vasil.stepcore.survival.SeasonDiamondView
                android:id="@+id/expeditionSeasonView"
                android:layout_width="52dp"
                android:layout_height="52dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/expeditionLabelText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ЭКСПЕДИЦИЯ (BETA)"
                    android:textColor="@color/accent_amber_bright"
                    android:letterSpacing="0.06"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/expeditionDayText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Нет активной экспедиции"
                    android:textColor="@color/text_main"
                    android:textSize="20sp"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/expeditionSubText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Начать →"
                    android:textColor="@color/accent_amber"
                    android:textSize="18sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
        </FrameLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:id="@+id/calibrationButton"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginEnd="5dp">
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Калибровка" android:textColor="@color/text_main" android:textSize="17sp" />
                <TextView
                    android:id="@+id/calibrationAccuracyText"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="@color/accent_violet_bright"
                    android:textSize="13sp" android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/historyButton"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginStart="5dp">
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="История" android:textColor="@color/text_dim" android:textSize="17sp" />
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/hapticSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Вибрация на шаг"
            android:textColor="@color/text_main"
            android:textSize="19sp"
            android:layout_marginTop="11dp" />

        <TextView
            android:id="@+id/toolsToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙  Инструменты  ▾"
            android:textColor="@color/text_dim"
            android:textSize="18sp"
            android:letterSpacing="0.05"
            android:paddingTop="18dp"
            android:paddingBottom="10dp" />

        <LinearLayout
            android:id="@+id/toolsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/tools_zone"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ЗОНА РАЗРАБОТКИ"
                    android:textColor="@color/axis_dim"
                    android:textSize="12sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Здесь ничего не сломается, но и красиво не будет. Это приборы, а не интерфейс."
                    android:textColor="@color/axis_dim"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="@color/accent_violet" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="0dp">
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/detailLogSwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Подробный журнал"
                            android:textColor="@color/accent_violet_bright"
                            android:textSize="17sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Строка в журнал каждые 5 секунд, корпус пишется вдвое плотнее. Непрерывный режим — на обычной ходьбе держи выключенным."
                            android:textColor="@color/text_dim"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="@color/accent_amber" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="10dp">
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/bgAccelSwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Сбор при выключенном экране"
                            android:textColor="@color/accent_amber_bright"
                            android:textSize="17sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Признаки собираются и с заблокированным экраном, окнами по 12 секунд раз в минуту. Счёт шагов не меняется. ЖРЁТ БАТАРЕЮ — включай только на замер."
                            android:textColor="@color/text_dim"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="@color/accent_teal" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="10dp">
                        <Button
                            android:id="@+id/reconcileButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Сверка с чипом сейчас" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Разовое измерение. Пишет в журнал, сколько насчитал StepCore и сколько чип. Счёт не прерывается. Главный показатель качества."
                            android:textColor="@color/text_dim"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="@color/accent_blue" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="10dp">
                        <Button
                            android:id="@+id/diagButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Замер детектора: старт" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Сессия сбора статистики пиков. На СТОПе печатает сводку в журнал. Нужен редко, для разбора детектора."
                            android:textColor="@color/text_dim"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />
                        <TextView
                            android:id="@+id/diagText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/accent_blue_bright"
                            android:fontFamily="monospace"
                            android:textSize="13sp"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="@color/accent_green" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="10dp">
                        <TextView
                            android:id="@+id/corpusText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Корпус: —"
                            android:textColor="@color/text_main"
                            android:fontFamily="monospace"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Размеченные образцы походки. Копятся сами, пока идёт счёт. Метки «в гору» и «с горы» появляются только от твоего нажатия — из шторки или с кнопок выше."
                            android:textColor="@color/text_dim"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

    </LinearLayout>
</ScrollView>
