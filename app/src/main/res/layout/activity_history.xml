<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/filter7" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="7д" />
            <Button android:id="@+id/filter30" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="30д" />
            <Button android:id="@+id/filter365" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Год" />
            <Button android:id="@+id/filterAll" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Всё" />
        </LinearLayout>

        <TextView
            android:id="@+id/summaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:id="@+id/daysContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <Button android:id="@+id/copyButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Копия" />
            <Button android:id="@+id/exportCsvButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="CSV" />
            <Button android:id="@+id/exportJsonButton" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="JSON" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Удаление всей истории"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp" />

        <EditText
            android:id="@+id/deleteConfirmInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введи: УДАЛИТЬ ДАННЫЕ"
            android:inputType="text" />

        <Button
            android:id="@+id/deleteButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Удалить" />

    </LinearLayout>
</ScrollView>
