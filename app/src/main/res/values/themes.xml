<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StepCore" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_red</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_main</item>
        <item name="colorOnBackground">@color/text_main</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- V14.0: рукописный шрифт (Caveat, OFL, кириллица полная) на всё
             приложение. Явные fontFamily в разметке сняты, иначе они бы
             перекрыли тему. Исключение - monospace в диагностике: там
             моноширинность несёт смысл (колонки чисел). -->
        <item name="android:fontFamily">@font/rubik</item>
        <item name="fontFamily">@font/rubik</item>
    </style>
</resources>
