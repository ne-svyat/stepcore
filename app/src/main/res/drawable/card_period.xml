<?xml version="1.0" encoding="utf-8"?>
<!-- Карточка сводки ЗА ПЕРИОД: синяя акцент-полоса слева (V9.17). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_blue" />
            <corners android:topLeftRadius="2dp" android:topRightRadius="20dp"
                android:bottomRightRadius="20dp" android:bottomLeftRadius="20dp" />
        </shape>
    </item>
    <item android:left="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
            <corners android:topLeftRadius="0dp" android:topRightRadius="20dp"
                android:bottomRightRadius="20dp" android:bottomLeftRadius="20dp" />
        </shape>
    </item>
</layer-list>
